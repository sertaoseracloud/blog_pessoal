---
import { loadData } from '../utils/data';
import { validateRepo } from '../utils/validation';

interface Repo {
  name: string;
  description: string;
  url: string;
  language: string;
}

const repos: Repo[] = await loadData('repos.json', validateRepo);
---

<div class="repos-grid">
  {repos.map((repo) => (
    <a href={repo.url} target="_blank" rel="noopener" class="repo-card card">
      <h3>{repo.name}</h3>
      <p>{repo.description}</p>
      <span class="tag">{repo.language}</span>
    </a>
  ))}
</div>

<style>
  .repos-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .repo-card { display: block; color: var(--text-primary); }
  .repo-card h3 { color: var(--accent); margin-bottom: 0.5rem; }
  .repo-card p { color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 0.5rem; }
</style>
