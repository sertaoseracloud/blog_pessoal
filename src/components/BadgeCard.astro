---
interface Props {
  badge: {
    name: string;
    issuer: string;
    imageUrl: string;
    credentialUrl: string;
    expiresDate?: string; // kept in data but not displayed
  };
}

const { badge } = Astro.props;
---

<a href={badge.credentialUrl} target="_blank" rel="noopener" class="card badge-card">
  <img src={badge.imageUrl} alt={badge.name} class="badge-image" loading="lazy" />
  <div class="badge-info">
    <h3 class="badge-name">{badge.name}</h3>
    <p class="badge-issuer">{badge.issuer}</p>
    {/* Expiration date hidden */}
  </div>
</a>

<style>
  .badge-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.5rem;
  }
  .badge-image {
    max-height: 120px;
    object-fit: contain;
    margin-bottom: 0.25rem;
  }
  .badge-name {
    font-size: 1rem;
    margin-bottom: 0.2rem;
    line-height: 1.3;
  }
  .badge-issuer {
    color: var(--text-secondary);
    font-size: 0.85rem;
    margin-bottom: 0;
  }
</style>
