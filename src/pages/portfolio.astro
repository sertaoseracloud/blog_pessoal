---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectTimeline from '../components/ProjectTimeline.astro';
import BadgeCard from '../components/BadgeCard.astro';
import { loadData } from '../utils/data';
import { validateProject, validateCertification } from '../utils/validation';

const projects = await loadData('projects.json', validateProject);
const rawBadges = await loadData('credly/badges.json');

// Group badges by issuer (provider)
interface BadgeGroup {
  [issuer: string]: Array<{
    name: string;
    issuer: string;
    imageUrl: string;
    credentialUrl: string;
    expiresDate?: string;
  }>;
}
const badgesByIssuer: BadgeGroup = rawBadges.reduce((acc, badge) => {
  const issuer = badge.issuer;
  if (!acc[issuer]) acc[issuer] = [];
  acc[issuer].push(badge);
  return acc;
}, {} as BadgeGroup);

const publications = await loadData('publications.json', validateCertification);
---

<BaseLayout title="Portfólio — Cláudio Raposo" currentPage="portfolio">
  <main>
    <section class="container section">
      <h2 class="section-title">Projetos — Timeline</h2>
      <ProjectTimeline projects={projects} />
    </section>

    <section class="container section">
      <h2 class="section-title">Certificações</h2>
      {Object.entries(badgesByIssuer).map(([issuer, issuerBadges]) => (
        <div class="issuer-group">
          <h3 class="issuer-title">{issuer}</h3>
          <div class="cert-grid">
            {issuerBadges.map(badge => <BadgeCard badge={badge} />)}
          </div>
        </div>
      ))}
    </section>

    <section class="container section">
      <h2 class="section-title">Publicações Científicas</h2>
      <div class="pub-list">
        {publications.map((pub) => (
          <div class="card pub-card">
            <h3>{pub.title}</h3>
            <p class="pub-venue">{pub.venue}</p>
            {pub.year && <span class="pub-year">{pub.year}</span>}
            {pub.citations && <span class="pub-citations">{pub.citations} citações</span>}
          </div>
        ))}
      </div>
    </section>

    <section class="container section">
      <h2 class="section-title">Formação Acadêmica</h2>
      <div class="edu-list">
        <div class="card edu-item">
          <h3>Mestrado em Administração</h3>
          <p class="edu-school">Must University — Estados Unidos</p>
        </div>
        <div class="card edu-item">
          <h3>Doctor Honoris Causa em Ciência da Computação</h3>
          <p class="edu-school">Hon.D.Sc.</p>
        </div>
        <div class="card edu-item">
          <h3>MBAs &amp; Especializações</h3>
          <p class="edu-school">Finanças, Projetos, Ciência de Dados, Docência</p>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .pub-list, .edu-list { display: flex; flex-direction: column; gap: 1rem; }
  .pub-card h3 { margin-bottom: 0.5rem; }
  .pub-venue { color: var(--text-secondary); margin-bottom: 0.5rem; }
  .pub-year, .pub-citations {
    display: inline-block;
    background: var(--bg-tertiary);
    color: var(--accent);
    padding: 0.15rem 0.5rem;
    border-radius: 10px;
    font-size: 0.75rem;
    margin-right: 0.5rem;
  }
  .edu-item h3 { margin-bottom: 0.3rem; }
  .edu-school { color: var(--text-secondary); }

  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .issuer-group {
    margin-bottom: 2.5rem;
  }

  .issuer-title {
    font-size: var(--text-h3);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
    color: var(--text-primary);
  }
